## 五、API 调用规范

```tsx
// lib/api.ts — 统一封装
const API_BASE = import.meta.env.VITE_API_URL || '/api/v1';

async function request<T>(path: string, options?: RequestInit): Promise<T> {
  const token = getAuthToken();
  const res = await fetch(`${API_BASE}${path}`, {
    ...options,
    headers: {
      'Content-Type': 'application/json',
      ...(token && { Authorization: `Bearer ${token}` }),
      ...options?.headers,
    },
  });

  if (!res.ok) {
    const err = await res.json();
    console.error(`API Error [${res.status}]: ${err.message}`);
    throw new Error(err.message || '请求失败');
  }

  return res.json();
}

// 使用示例
export const lessonPlanApi = {
  list: (params: { page: number; pageSize: number }) =>
    request<PaginatedResponse<LessonPlan>>(`/lesson-plans?page=${params.page}&page_size=${params.pageSize}`),

  get: (id: string) =>
    request<LessonPlan>(`/lesson-plans/${id}`),

  generate: (id: string, data: GenerateRequest) =>
    request<{ taskId: string }>(`/lesson-plans/${id}/generate`, {
      method: 'POST',
      body: JSON.stringify(data),
    }),
};
```

