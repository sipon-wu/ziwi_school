# ── 知微AI教学助手 环境变量配置 ──
# 复制此文件为 .env 并填入真实值

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=zhiwei
DB_PASSWORD=zhiwei2026    # 生产环境务必修改！
DB_NAME=zhiwei

# Redis
REDIS_URL=localhost:6379

# AI 服务
AI_SERVICE_URL=http://ai-service:8000

# JWT（生产环境请使用至少32位随机字符串）
# 生成方式: openssl rand -base64 32
JWT_PRIVATE_KEY=change-me-in-production-use-32-chars

# 通义千问 API Key
DASHSCOPE_API_KEY=

# 微信小程序
WECHAT_APPID=
WECHAT_SECRET=

# 短信服务
SMS_ACCESS_KEY=
SMS_SECRET=

# 对象存储
OSS_ACCESS_KEY=
OSS_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# 演示环境
DEMO_RESET_PASSWORD=reset-demo-data
