.page { padding-bottom: 120rpx; }
.title { font-size: 34rpx; font-weight: 600; display: block; margin-bottom: 20rpx; }
.info { font-size: 28rpx; color: var(--text-secondary); line-height: 2; }

.sign-area { position: relative; }
.label { font-size: 26rpx; color: var(--text-hint); display: block; margin-bottom: 16rpx; }
.canvas {
  width: 100%; height: 360rpx;
  background: #fafafa; border: 2rpx dashed var(--border);
  border-radius: 12rpx;
}
.clear-btn { position: absolute; right: 30rpx; bottom: 30rpx; font-size: 24rpx; color: var(--text-hint); }

.bottom-bar { display: flex; align-items: flex-start; gap: 12rpx; padding: 20rpx 30rpx; }
.agree-text { font-size: 26rpx; color: var(--text-secondary); flex: 1; }
.submit-btn { margin: 20rpx 30rpx; }
.submit-btn.disabled { opacity: 0.4; }

.success-page {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 200rpx;
}
.success-icon { font-size: 80rpx; margin-bottom: 30rpx; }
.success-title { font-size: 36rpx; font-weight: 600; margin-bottom: 16rpx; }
.success-desc { font-size: 28rpx; color: var(--text-hint); }
